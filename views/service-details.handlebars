<main class="main">

    <div class="page-title dark-background" style="background-image: url(/img/hero-carousel/hero-carousel-1.jpg);">
        <div class="container position-relative">
            <h1>{{details.category}}</h1>
            <nav class="breadcrumbs">
                <ol>
                    <li><a href="/">Home</a></li>
                    <li><a href="/services">Services</a></li>
                    <li class="current">{{details.category}}</li>
                </ol>
            </nav>
        </div>
    </div>


    <section id="service-details" class="service-details section">
        <div class="container">

            <div class="row gy-4">

                <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">

                    <div class="services-list">
                        <a href="#" class="readmore active">See All
                            Products <i class="bi bi-arrow-right"></i></a>
                        {{#each details.items}}
                            <a href="#" class="">{{this}}</a>
                        {{/each}}

                    </div>

                    <div class="card text-center" style="max-width: 400px; margin: auto;">
                        <div class="card-body">
                            <h3 class="card-title text-g">Sign In &amp; Shop</h3>
                            <p class="card-text">
                                Access exclusive products made with purpose. Sign in to explore our catalog, manage your
                                orders, and support
                                Kansas Correctional Industries.
                            </p>

                            <a href="/signIn" class="btn btn-y mt-3">Sign In</a>
                            <p class="mt-4">Need an account? <span class="text-y"><a href="/">Register Here.</a></span>
                            </p>
                        </div>
                    </div>

                </div>

                <div class="col-lg-8" data-aos="fade-up" data-aos-delay="200">

                    <div class="row">

                        <div class="col-lg-4 col-md-12 mb-4 mb-lg-0">
                            <img src="/../img/service-details/{{details.short}}-1.png"
                                class="w-40 shadow-1-strong rounded mb-4" />

                            <img src="/../img/service-details/{{details.short}}-2.png"
                                class="w-40 shadow-1-strong rounded mb-4" />
                        </div>

                        <div class="col-lg-4 mb-4 mb-lg-0">
                            <img src="/../img/service-details/{{details.short}}-3.png"
                                class="w-40 shadow-1-strong rounded mb-4" />

                            <img src="/../img/service-details/{{details.short}}-4.png"
                                class="w-40 shadow-1-strong rounded mb-4" />
                        </div>

                        <div class="col-lg-4 mb-4 mb-lg-0">
                            <img src="/../img/service-details/{{details.short}}-5.png"
                                class="w-40 shadow-1-strong rounded mb-4" />

                            <img src="/../img/service-details/{{details.short}}-6.png"
                                class="w-40 shadow-1-strong rounded mb-4" />
                        </div>
                    </div>
                    <!-- Gallery -->
                    <h3>{{details.overview.title}}</h3>
                    <p>
                        {{details.overview.content}}
                    </p>
                    <ul>

                        {{#each details.keyOfferings}}

                            <li><i class="bi bi-check-circle"></i>
                                <span>{{this.description}}</span>
                            </li>
                        {{/each}}
                    </ul>
                </div>
            </div>
        </div>
    </section>
</main>