<main class="main">

    <div class="page-title dark-background" style="background-image: url(/img/hero-carousel/hero-carousel-1.jpg);">
        <div class="container position-relative">
            <h1>{{details.category}}</h1>
            <nav class="breadcrumbs">
                <ol>
                    <li><a href="/">Home</a></li>
                    <li class="current">{{details.category}}</li>
                </ol>
            </nav>
        </div>
    </div>


    <section id="service-details" class="service-details section">
        <div class="container">
            <div class="row gy-4">
                <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="services-list">
                        {{#each details.items}}
                            <a href="#" class="active">{{this}}</a>
                        {{/each}}

                    </div>

                    <h4>{{details.category}}</h4>
                    <p>{{details.description}}</p>
                </div>

                <div class="col-lg-8" data-aos="fade-up" data-aos-delay="200">
                    <img src="/img/services.jpg" alt="" class="img-fluid services-img" />
                    <h3>{{details.overview.title}}</h3>
                    <p>
                        {{details.overview.content}}
                    </p>
                    <ul>

                        {{#each details.keyOfferings}}

                            <li><i class="bi bi-check-circle"></i>
                                <span>{{this.description}}</span>
                            </li>
                        {{/each}}
                    </ul>
                </div>
            </div>
        </div>
    </section>
</main>